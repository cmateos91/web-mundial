---
import Base from '../layouts/Base.astro'
import { sedes } from '../data/sedes.ts'

const formatNum = (n: number) => n.toLocaleString('es-Es')
---

<Base titulo="Sedes">
	<h1 class="text-4xl font-bold">Sedes</h1>
	<p>Aquí veras las sedes</p>
    {sedes.map(sede => (
        <div class="p-4 border-b">
            <h1 class="text-xl font-semibold">{sede.pais}</h1>
            <h2 class="text-xl">{sede.ciudad}</h2>
            <p>{sede.estadio} - {formatNum(sede.capacidad)} espectadores</p>
        </div>
    ))}
</Base>