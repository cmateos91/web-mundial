---
import Base from '../layouts/Base.astro'
import EditorialIntro from '../components/EditorialIntro.astro'
import HostCityConstellation from '../components/HostCityConstellation.astro'
import { sedes } from '../data/sedes'
import { partidosPorEstadio } from '../data/conteos'
import TarjetasSedes from '../components/TarjetasSedes.astro'

const sedesMexico = sedes.filter(sede => sede.pais === 'México')
const sedesUSA = sedes.filter(sede => sede.pais === 'Estados Unidos')
const sedesCanada = sedes.filter(sede => sede.pais === 'Canadá')

const capacidadMax = Math.max(...sedes.map(s => s.capacidad))
---

<Base titulo="Sedes — Mundial 2026" descripcion="Las 16 sedes del Mundial 2026 en Canadá, México y Estados Unidos." pageTone="venues">
	<EditorialIntro
		etiqueta="Escala continental"
		titulo="Sedes"
		descripcion="Dieciséis estadios repartidos entre tres países para el Mundial más grande jamás organizado. Cada ciudad sede es una etapa distinta dentro del recorrido del torneo."
		stats={[
			{ valor: '16', etiqueta: 'estadios' },
			{ valor: '3', etiqueta: 'países' },
			{ valor: '104', etiqueta: 'partidos' },
			{ valor: capacidadMax.toLocaleString('es-ES'), etiqueta: 'mayor aforo' },
		]}
	/>

	<section class="mb-8" data-reveal="up">
		<HostCityConstellation
			compact={true}
			etiqueta="Cartografía de sedes"
			titulo="Un mapa de rutas, ciudades y estadios anfitriones"
			descripcion="La pieza inmersiva del torneo se vuelve aquí más informativa: una lectura visual de cómo se reparte el Mundial por Norteamérica."
		/>
	</section>

	<TarjetasSedes pais="México" bandera="🇲🇽" sedes={sedesMexico} capacidadMax={capacidadMax} partidosPorEstadio={partidosPorEstadio} />
	<TarjetasSedes pais="Estados Unidos" bandera="🇺🇸" sedes={sedesUSA} capacidadMax={capacidadMax} partidosPorEstadio={partidosPorEstadio} />
	<TarjetasSedes pais="Canadá" bandera="🇨🇦" sedes={sedesCanada} capacidadMax={capacidadMax} partidosPorEstadio={partidosPorEstadio} />
</Base>
