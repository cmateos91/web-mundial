---
import Base from '../../layouts/Base.astro'
import EditorialTicker from '../../components/EditorialTicker.astro'
import { grupos } from '../../data/grupos'
import { jornadas } from '../../data/partidos'
import { paises } from '../../data/paises'
import { calcularClasificacion, grupoPorEquipo } from '../../data/clasificacion'
import { slugificar, slugPorEquipo } from '../../data/slugs'

export function getStaticPaths() {
	const equipos = grupos.flatMap(g => g.equipos)
	// Filtrar "Por definir" y evitar slugs duplicados
	const vistos = new Set<string>()
	return equipos
		.filter(e => !e.startsWith('Por definir'))
		.filter(e => {
			const slug = slugificar(e)
			if (vistos.has(slug)) return false
			vistos.add(slug)
			return true
		})
		.map(equipo => ({
			params: { equipo: slugificar(equipo) },
			props: { nombre: equipo }
		}))
}

const { nombre } = Astro.props

// Datos del equipo
const paisInfo = paises.find(p => p.nombre === nombre)
const bandera = paisInfo?.bandera ?? ''
const nombreGrupo = grupoPorEquipo.get(nombre) ?? ''
const grupo = grupos.find(g => g.nombre === nombreGrupo)

// Clasificación de su grupo
const clasificacion = calcularClasificacion()
const tablaGrupo = clasificacion.get(nombreGrupo) ?? []
const posicion = tablaGrupo.findIndex(e => e.equipo === nombre) + 1
const statsEquipo = tablaGrupo.find((equipo) => equipo.equipo === nombre)

// Partidos del equipo
const partidosEquipo = jornadas.flatMap(j =>
	j.partidos
		.filter(p => p.equipo1 === nombre || p.equipo2 === nombre)
		.map(p => ({ ...p, fecha: j.fecha }))
)

// Sedes donde juega
const sedesUnicas = [...new Set(
	partidosEquipo
		.filter(p => p.estadio !== 'Por confirmar')
		.map(p => `${p.estadio}, ${p.ciudad}`)
)]

const rivalesGrupo = (grupo?.equipos ?? []).filter((equipo) => equipo !== nombre)
const rivalesConfirmados = rivalesGrupo.filter((equipo) => equipo !== 'Por definir')
const plazasPendientes = rivalesGrupo.filter((equipo) => equipo === 'Por definir').length
const siguientePartido = partidosEquipo.find((partido) => partido.estado !== 'finalizado') ?? partidosEquipo[0]
const rivalSiguiente = siguientePartido
	? (siguientePartido.equipo1 === nombre ? siguientePartido.equipo2 : siguientePartido.equipo1)
	: null
const anfitriones = new Set(['México', 'Estados Unidos', 'Canadá'])
const esAnfitrion = anfitriones.has(nombre)
const diferenciaGoles = statsEquipo ? statsEquipo.gf - statsEquipo.gc : 0
const balance = statsEquipo ? `${statsEquipo.pg}-${statsEquipo.pe}-${statsEquipo.pp}` : '0-0-0'
const resumenRuta = statsEquipo && statsEquipo.pj > 0
	? `${nombre} ocupa ahora la ${posicion}ª plaza de ${nombreGrupo} con ${statsEquipo.pts} puntos, balance ${balance} y una diferencia de goles de ${diferenciaGoles >= 0 ? '+' : ''}${diferenciaGoles}.`
	: esAnfitrion
		? `${nombre} llega a la fase inicial bajo presión anfitriona, con foco total sobre su grupo y una lectura que mezcla expectativa, calendario y narrativa nacional.`
		: plazasPendientes > 0
			? `${nombreGrupo} todavía mantiene ${plazasPendientes} plaza por definir, así que el recorrido de ${nombre} se lee con margen para un último giro competitivo.`
			: `${nombre} comparte grupo con ${rivalesConfirmados.join(', ')} en un cuadro ya cerrado y listo para medirse por jerarquía, ritmo y detalle.`
---

<Base titulo={`${nombre} — Mundial 2026`} descripcion={`Perfil editorial de ${nombre} en el Mundial 2026.`} pageTone="team">
	<section class="team-hero panel p-5" data-reveal="up">
		<div>
			<a href="/grupos" class="editorial-link">← Volver a grupos</a>
			<div class="team-hero__identity mt-5">
				{bandera && <span class="team-flag">{bandera}</span>}
				<div>
					<p class="section-kicker mb-3">Perfil de selección</p>
					<h1 class="page-title" data-equipo={nombre}>{nombre}</h1>
					<p class="page-lead mt-4">
						{nombreGrupo} · Posición actual {posicion}º · {partidosEquipo.length} partidos previstos en la fase de grupos.
					</p>
				</div>
			</div>
		</div>

		<div class="page-intro__stats">
			<div class="stat-card">
				<strong>{nombreGrupo.replace('Grupo ', '')}</strong>
				<span>grupo</span>
			</div>
			<div class="stat-card">
				<strong>{posicion}º</strong>
				<span>posición</span>
			</div>
			<div class="stat-card">
				<strong>{partidosEquipo.length}</strong>
				<span>partidos</span>
			</div>
			<div class="stat-card">
				<strong>{sedesUnicas.length || 1}</strong>
				<span>sedes</span>
			</div>
		</div>
	</section>

	<EditorialTicker
		items={[
			{
				label: 'Grupo',
				value: nombreGrupo.replace('Grupo ', ''),
				note: `${nombre} comparte cuadro con ${rivalesConfirmados.join(', ')}${plazasPendientes > 0 ? ' y una plaza pendiente.' : '.'}`,
			},
			{
				label: 'Balance',
				value: balance,
				note: statsEquipo && statsEquipo.pj > 0 ? 'Victorias, empates y derrotas en la tabla provisional.' : 'La fase todavía no deja balance competitivo real.',
			},
			{
				label: 'Siguiente foco',
				value: rivalSiguiente ?? 'Por definir',
				note: siguientePartido ? `${siguientePartido.fecha} · ${siguientePartido.estadio === 'Por confirmar' ? 'sede pendiente' : siguientePartido.estadio}` : 'Sin partido asignado en este momento.',
			},
			{
				label: 'Escenarios',
				value: String(sedesUnicas.length || 1),
				note: sedesUnicas.length > 0 ? 'Sedes ya visibles dentro de la agenda conocida.' : 'La ruta aún espera confirmación de estadios.',
			},
		]}
	/>

	<section class="team-editorial-shell" data-reveal="up">
		<div class="team-panel tarjeta team-panel--lead">
			<p class="section-kicker">Estado de la ruta</p>
			<h2 class="feature-title">Hoja de grupo</h2>
			<p class="feature-copy">{resumenRuta}</p>

			<div class="team-metric-grid">
				<div>
					<strong>{statsEquipo?.pts ?? 0}</strong>
					<span>puntos</span>
				</div>
				<div>
					<strong>{statsEquipo?.gf ?? 0}</strong>
					<span>goles a favor</span>
				</div>
				<div>
					<strong>{statsEquipo?.gc ?? 0}</strong>
					<span>goles en contra</span>
				</div>
				<div>
					<strong>{diferenciaGoles >= 0 ? `+${diferenciaGoles}` : diferenciaGoles}</strong>
					<span>diferencia</span>
				</div>
			</div>
		</div>

		<div class="team-panel tarjeta team-panel--aside" data-reveal="up" style="--reveal-delay: 0.08s;">
			<p class="section-kicker">Siguiente foco</p>
			{siguientePartido ? (
				<div class="team-next-match">
					<h2 class="feature-title">{rivalSiguiente}</h2>
					<p class="feature-copy">
						{nombre} volverá a escena el {siguientePartido.fecha} a las <span data-utc={siguientePartido.fechaUTC}>{siguientePartido.hora}</span>.
					</p>
					<div class="team-next-match__meta">
						<span class="fixture-count-badge">{siguientePartido.estado === 'finalizado' ? 'jugado' : 'pendiente'}</span>
						<span class="fixture-count-badge">
							{siguientePartido.estadio === 'Por confirmar' ? 'sede pendiente' : siguientePartido.estadio}
						</span>
					</div>
				</div>
			) : (
				<div class="team-next-match">
					<h2 class="feature-title">Agenda en espera</h2>
					<p class="feature-copy">Todavía no hay un siguiente cruce visible para esta selección.</p>
				</div>
			)}
		</div>
	</section>

	<div class="team-grid">
		<div class="grid gap-5">
			<section class="team-panel tarjeta" data-reveal="up">
				<p class="section-kicker">Grupo</p>
				<h2 class="feature-title">{nombreGrupo}</h2>
				<div class="overflow-x-auto mt-5">
					<table class="group-table">
						<thead>
							<tr>
								<th class="text-left">Equipo</th>
								<th>PJ</th>
								<th>GF</th>
								<th>GC</th>
								<th>Pts</th>
							</tr>
						</thead>
						<tbody>
							{tablaGrupo.map((e, i) => (
								<tr class:list={[{ qualifier: i < 2 }]}>
									<td>
										{e.equipo === nombre
											? <span class="group-table__team font-semibold" data-equipo={e.equipo}><span class="team-rank">{i + 1}.</span>{e.equipo}</span>
											: slugPorEquipo.has(e.equipo)
												? <a href={`/equipos/${slugPorEquipo.get(e.equipo)}`} class="group-table__team" data-equipo={e.equipo}><span class="team-rank">{i + 1}.</span>{e.equipo}</a>
												: <span class="group-table__team"><span class="team-rank">{i + 1}.</span>{e.equipo}</span>
										}
									</td>
									<td class="text-center">{e.pj}</td>
									<td class="text-center">{e.gf}</td>
									<td class="text-center">{e.gc}</td>
									<td class="text-center font-semibold">{e.pts}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>

			<section class="team-panel tarjeta" data-reveal="up" style="--reveal-delay: 0.06s;">
				<p class="section-kicker">Rivales del grupo</p>
				<h2 class="feature-title">El marco competitivo</h2>
				<div class="team-opponent-list mt-5">
					{rivalesGrupo.map((equipo) => (
						equipo === 'Por definir' ? (
							<span class="team-opponent-badge">Por definir</span>
						) : slugPorEquipo.has(equipo) ? (
							<a href={`/equipos/${slugPorEquipo.get(equipo)}`} class="team-opponent-link" data-equipo={equipo}>
								{equipo}
							</a>
						) : (
							<span class="team-opponent-badge" data-equipo={equipo}>{equipo}</span>
						)
					))}
				</div>
			</section>

			{sedesUnicas.length > 0 && (
				<section class="team-panel tarjeta" data-reveal="up" style="--reveal-delay: 0.12s;">
					<p class="section-kicker">Escenario</p>
					<h2 class="feature-title">Sedes previstas</h2>
					<div class="grid gap-3 mt-5">
						{sedesUnicas.map(sede => (
							<div class="score-badge w-fit">{sede}</div>
						))}
					</div>
				</section>
			)}
		</div>

		<section class="team-panel tarjeta" data-reveal="up">
			<p class="section-kicker">Agenda de la selección</p>
			<h2 class="feature-title">Partidos ({partidosEquipo.length})</h2>
			<div class="grid gap-4 mt-5">
				{partidosEquipo.map(p => (
					<article class="match-editorial-card tarjeta">
						<div class="match-editorial-card__top">
							<div>
								<p class="match-time" data-utc={p.fechaUTC}>{p.hora}</p>
								<p class="match-meta">{p.fecha}</p>
							</div>
							<span class="score-badge">
								{p.estado === 'finalizado' ? `${p.goles1} - ${p.goles2}` : 'vs'}
							</span>
						</div>

						<div>
							<p class="match-teams">
								<span data-equipo={p.equipo1} class={p.equipo1 === nombre ? 'font-semibold' : ''}>{p.equipo1}</span>
								{' · '}
								<span data-equipo={p.equipo2} class={p.equipo2 === nombre ? 'font-semibold' : ''}>{p.equipo2}</span>
							</p>
							<p class="match-meta mt-2">
								{p.estadio === 'Por confirmar'
									? 'Sede por confirmar'
									: `${p.estadio}, ${p.ciudad}`}
							</p>
						</div>
					</article>
				))}
			</div>
		</section>
	</div>
</Base>
