---
import Base from "../layouts/Base.astro"
import { jornadas } from "../data/partidos"
import FiltroPartidos from "../components/FiltroPartidos"
---

<Base titulo="Partidos — Mundial 2026">
	<div class="mb-8">
		<h1 class="text-4xl font-extrabold">Partidos</h1>
		<p class="texto-secundario mt-1">Calendario completo de la fase de grupos del Mundial 2026.</p>
	</div>
	<FiltroPartidos client:visible jornadas={jornadas} />
</Base>
