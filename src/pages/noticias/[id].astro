---
import { getCollection, render } from 'astro:content'
import Base from '../../layouts/Base.astro'
import NewsStoryArtwork from '../../components/NewsStoryArtwork.astro'

export async function getStaticPaths() {
  const noticias = await getCollection('noticias')
  return noticias.map((noticia) => ({
    params: { id: noticia.id },
    props: { noticia },
  }))
}

const { noticia } = Astro.props
const { Content } = await render(noticia)
---

<Base
  titulo={`${noticia.data.titulo} — Mundial 2026`}
  descripcion={noticia.data.resumen}
  pageTone="news"
>
  <article class="article-shell">
    <div class="article-header panel">
      <div class="article-header__grid">
        <div>
          <a href="/noticias" class="editorial-link">← Volver a noticias</a>
          <div class="mt-6">
            <span class="article-kicker">Cobertura editorial</span>
            <h1 class="article-title mt-3">{noticia.data.titulo}</h1>
            <p class="article-summary">{noticia.data.resumen}</p>
          </div>

          <div class="hero-countdown mt-6">
            <div class="hero-countdown__number">{noticia.data.fecha.slice(0, 4)}</div>
            <div class="hero-countdown__copy">
              <strong>{noticia.data.fecha}</strong>
              <span>Fecha de publicación</span>
            </div>
          </div>
        </div>

        <NewsStoryArtwork id={noticia.id} title={noticia.data.titulo} variant="article" />
      </div>
    </div>

    <div class="article-copy panel">
      <Content />
    </div>
  </article>
</Base>
