---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import EditorialIntro from '../../components/EditorialIntro.astro'
import NewsStoryArtwork from '../../components/NewsStoryArtwork.astro'

const noticias = await getCollection('noticias')
noticias.sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime())

const noticiaPrincipal = noticias[0]
const noticiasRestantes = noticias.slice(1)
---

<Base
  titulo="Noticias — Mundial 2026"
  descripcion="Noticias del Mundial 2026: anuncios, sedes, formato y todo lo importante del torneo."
  pageTone="news"
>
  <EditorialIntro
    etiqueta="Noticias / edición viva"
    titulo="Lo que va dejando el Mundial 2026"
    descripcion="Anuncios, contexto y nombres propios de un torneo que no para quieto."
    stats={[
      { valor: String(noticias.length).padStart(2, '0'), etiqueta: 'Noticias en archivo' },
      { valor: '2026', etiqueta: 'Año del torneo' },
      { valor: 'Al día', etiqueta: 'Seguimiento' },
    ]}
  >
    <div class="hero-actions">
      <a href="/partidos" class="hero-cta">Ir al calendario</a>
      <a href="/sedes" class="hero-cta-secondary">Explorar sedes</a>
    </div>
  </EditorialIntro>

  <section class="editorial-stack">
    {noticiaPrincipal && (
      <a href={`/noticias/${noticiaPrincipal.id}`} class="panel news-feature panel-hover" data-reveal="up">
        <div>
          <h2 class="news-feature__title">{noticiaPrincipal.data.titulo}</h2>
          <p class="news-feature__summary">{noticiaPrincipal.data.resumen}</p>
          <div class="match-editorial-card__top mt-6">
            <span class="article-kicker">Portada</span>
            <time class="news-date">{noticiaPrincipal.data.fecha}</time>
          </div>
        </div>
        <NewsStoryArtwork id={noticiaPrincipal.id} title={noticiaPrincipal.data.titulo} variant="feature" />
      </a>
    )}

    <div class="editorial-section panel" data-reveal="up">
      <div class="editorial-section__head">
        <h2 class="editorial-section__title">Últimas noticias</h2>
        <span class="fixture-count-badge">{noticiasRestantes.length} noticias</span>
      </div>

      <div class="news-grid">
        {noticiasRestantes.map((noticia, index) => (
          <a href={`/noticias/${noticia.id}`} class="news-card tarjeta tarjeta-hover" data-reveal="up" style={`--reveal-delay: ${0.06 * index}s;`}>
            <NewsStoryArtwork id={noticia.id} title={noticia.data.titulo} />
            <div class="article-kicker">0{index + 2}</div>
            <h3 class="news-card__title mt-3">{noticia.data.titulo}</h3>
            <p class="news-card__summary mt-3">{noticia.data.resumen}</p>
            <div class="match-editorial-card__top mt-4">
              <span class="editorial-link">Leer nota</span>
              <time class="news-date">{noticia.data.fecha}</time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
