---
import { getCollection } from "astro:content"
import Base from '../../layouts/Base.astro'

const noticias = await getCollection('noticias')
// Ordenar por fecha descendente
noticias.sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime())
---

<Base titulo="Noticias — Mundial 2026">
    <div class="mb-8">
        <h1 class="text-4xl font-extrabold">Noticias</h1>
        <p class="texto-secundario mt-1">Las últimas novedades sobre el Mundial 2026.</p>
    </div>
    <div class="space-y-4">
        {noticias.map(noticia => (
            <a href={`/noticias/${noticia.id}`} class="tarjeta tarjeta-hover block p-5">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h2 class="text-lg font-bold">{noticia.data.titulo}</h2>
                        <p class="texto-secundario text-sm mt-1">{noticia.data.resumen}</p>
                    </div>
                    <time class="text-xs texto-secundario whitespace-nowrap mt-1">{noticia.data.fecha}</time>
                </div>
            </a>
        ))}
    </div>
</Base>
