---
import { getCollection } from 'astro:content'
import Base from '../../layouts/Base.astro'
import EditorialIntro from '../../components/EditorialIntro.astro'

const noticias = await getCollection('noticias')
noticias.sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime())

const noticiaPrincipal = noticias[0]
const noticiasRestantes = noticias.slice(1)
---

<Base
  titulo="Noticias — Mundial 2026"
  descripcion="Cobertura editorial del Mundial 2026: anuncios, sedes, formato y noticias clave del torneo."
  pageTone="news"
>
  <EditorialIntro
    etiqueta="Noticias / edición viva"
    titulo="La crónica visual del Mundial 2026"
    descripcion="Noticias tratadas como una revista deportiva: titulares con presencia, contexto claro y una narrativa que acompaña la escala continental del torneo."
    stats={[
      { valor: String(noticias.length).padStart(2, '0'), etiqueta: 'Piezas publicadas' },
      { valor: '2026', etiqueta: 'Temporada del torneo' },
      { valor: '24/7', etiqueta: 'Cobertura editorial' },
    ]}
  >
    <div class="hero-actions">
      <a href="/partidos" class="hero-cta">Ir al calendario</a>
      <a href="/sedes" class="hero-cta-secondary">Explorar sedes</a>
    </div>
  </EditorialIntro>

  <section class="editorial-stack">
    {noticiaPrincipal && (
      <a href={`/noticias/${noticiaPrincipal.id}`} class="panel news-feature panel-hover">
        <div class="news-feature__title">{noticiaPrincipal.data.titulo}</div>
        <p class="news-feature__summary">{noticiaPrincipal.data.resumen}</p>
        <div class="match-editorial-card__top">
          <span class="article-kicker">Portada</span>
          <time class="news-date">{noticiaPrincipal.data.fecha}</time>
        </div>
      </a>
    )}

    <div class="editorial-section panel">
      <div class="editorial-section__head">
        <h2 class="editorial-section__title">Archivo reciente</h2>
        <span class="fixture-count-badge">{noticiasRestantes.length} notas</span>
      </div>

      <div class="news-grid">
        {noticiasRestantes.map((noticia, index) => (
          <a href={`/noticias/${noticia.id}`} class="news-card tarjeta tarjeta-hover">
            <div class="article-kicker">0{index + 2}</div>
            <h3 class="news-card__title mt-3">{noticia.data.titulo}</h3>
            <p class="news-card__summary mt-3">{noticia.data.resumen}</p>
            <div class="match-editorial-card__top mt-4">
              <span class="editorial-link">Leer nota</span>
              <time class="news-date">{noticia.data.fecha}</time>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>
