---
import Base from '../layouts/Base.astro'
import { jornadas } from '../data/partidos'
import BuscadorEquipos from '../components/BuscadorEquipos'
import { grupos } from '../data/grupos'
import { slugPorEquipo } from '../data/slugs'

const proximosPartidos = jornadas[0].partidos
const slugsObj = Object.fromEntries(slugPorEquipo)

// Cuenta regresiva calculada en build time
const inicio = new Date('2026-06-11T00:00:00')
const hoy = new Date()
const diasRestantes = Math.max(0, Math.ceil((inicio.getTime() - hoy.getTime()) / (1000 * 60 * 60 * 24)))
---

<Base titulo="Mundial 2026 — Canadá, México, Estados Unidos">
	<!-- Hero -->
	<section class="relative text-center py-20 rounded-2xl mt-2 overflow-hidden bg-gradient-to-br from-[var(--color-verde)] via-[var(--color-rojo)] to-[var(--color-azul)]">
		<div class="relative z-10">
			<p class="text-white/80 text-sm font-medium uppercase tracking-widest mb-3">Copa Mundial de la FIFA</p>
			<h1 class="text-5xl md:text-7xl font-extrabold text-white drop-shadow-lg">Mundial 2026</h1>
			<p class="text-white/90 text-lg mt-3">Canadá &middot; México &middot; Estados Unidos</p>
			<p class="text-white/70 mt-1">11 de junio — 19 de julio de 2026</p>

			<div class="mt-8 inline-flex items-baseline gap-2 bg-white/15 backdrop-blur-sm rounded-xl px-6 py-3">
				<span id="cuenta-atras" class="text-4xl font-extrabold text-white">{diasRestantes}</span>
				<span class="text-white/80 text-sm">días para el inicio</span>
			</div>
			<script is:inline>
				(function() {
					var dias = Math.max(0, Math.ceil((new Date('2026-06-11').getTime() - Date.now()) / 864e5))
					var el = document.getElementById('cuenta-atras')
					if (el) el.textContent = dias
					if (dias === 0) el.parentElement.style.display = 'none'
				})()
			</script>

			<div class="mt-8">
				<a href="/partidos" class="inline-block px-8 py-3 bg-white text-[var(--color-verde)] font-bold rounded-xl hover:bg-white/90 transition-colors shadow-lg">
					Ver calendario de partidos
				</a>
			</div>
		</div>
	</section>

	<!-- Buscador -->
	<section class="mt-12">
		<h2 class="text-2xl font-bold mb-4">Busca tu equipo</h2>
		<BuscadorEquipos client:visible grupos={grupos} slugs={slugsObj} />
	</section>

	<!-- Primeros partidos -->
	<section class="mt-12">
		<div class="flex items-center justify-between mb-4">
			<h2 class="text-2xl font-bold">Primeros partidos</h2>
			<a class="text-sm font-medium text-[var(--color-verde)] hover:underline" href="/partidos">Ver todos →</a>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-2 gap-3">
			{proximosPartidos.map(partido => (
				<div class="tarjeta p-4 flex items-center gap-4">
					<span class="text-sm font-mono texto-secundario w-12 shrink-0" data-utc={partido.fechaUTC}>{partido.hora}</span>
					<div class="flex-1">
						<p class="font-semibold">
						<span data-equipo={partido.equipo1}>{partido.equipo1}</span>
						{partido.estado === 'finalizado'
							? <span class="mx-1 px-2 py-0.5 rounded fondo-superficie text-sm font-bold">{partido.goles1} - {partido.goles2}</span>
							: <span class="texto-secundario font-normal mx-1">vs</span>
						}
						<span data-equipo={partido.equipo2}>{partido.equipo2}</span>
					</p>
						<p class="text-sm texto-secundario">{partido.estadio}, {partido.ciudad}</p>
					</div>
				</div>
			))}
		</div>
	</section>

	<!-- Navegación rápida -->
	<section class="mt-12 mb-4">
		<h2 class="text-2xl font-bold mb-4">Explora el mundial</h2>
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
			<a href="/grupos" class="tarjeta tarjeta-hover p-6 border-l-4 border-l-[var(--color-verde)]">
				<h3 class="text-lg font-bold">Grupos</h3>
				<p class="texto-secundario text-sm mt-1">12 grupos con tabla de posiciones</p>
			</a>
			<a href="/partidos" class="tarjeta tarjeta-hover p-6 border-l-4 border-l-[var(--color-rojo)]">
				<h3 class="text-lg font-bold">Partidos</h3>
				<p class="texto-secundario text-sm mt-1">104 partidos con filtros</p>
			</a>
			<a href="/eliminatorias" class="tarjeta tarjeta-hover p-6 border-l-4 border-l-[var(--color-azul)]">
				<h3 class="text-lg font-bold">Eliminatorias</h3>
				<p class="texto-secundario text-sm mt-1">Bracket de dieciseisavos a la final</p>
			</a>
			<a href="/sedes" class="tarjeta tarjeta-hover p-6 border-l-4 border-l-[var(--color-verde)]">
				<h3 class="text-lg font-bold">Sedes</h3>
				<p class="texto-secundario text-sm mt-1">16 estadios en 3 países</p>
			</a>
		</div>
	</section>
</Base>
