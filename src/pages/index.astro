---
import Base from '../layouts/Base.astro'
import { getCollection } from 'astro:content'
import { jornadas } from '../data/partidos'
import BuscadorEquipos from '../components/BuscadorEquipos'
import { grupos } from '../data/grupos'
import { slugPorEquipo } from '../data/slugs'
import HostCityConstellation from '../components/HostCityConstellation.astro'
import { sedes } from '../data/sedes'
import EditorialTicker from '../components/EditorialTicker.astro'
import HostNationCards from '../components/HostNationCards.astro'
import NewsStoryArtwork from '../components/NewsStoryArtwork.astro'

const proximosPartidos = jornadas.flatMap((jornada) =>
  jornada.partidos.map((partido) => ({ ...partido, fecha: jornada.fecha }))
).slice(0, 6)
const slugsObj = Object.fromEntries(slugPorEquipo)
const noticias = await getCollection('noticias')
noticias.sort((a, b) => new Date(b.data.fecha).getTime() - new Date(a.data.fecha).getTime())
const destacadas = noticias.slice(0, 2)
const totalPartidosEdicion = 104
const totalSedes = sedes.length

// Cuenta regresiva calculada en build time
const inicio = new Date('2026-06-11T00:00:00')
const hoy = new Date()
const diasRestantes = Math.max(0, Math.ceil((inicio.getTime() - hoy.getTime()) / (1000 * 60 * 60 * 24)))
---

<Base
	titulo="Mundial 2026 — Canadá, México, Estados Unidos"
	descripcion="Toda la información del Mundial 2026 con grupos, partidos, sedes, eliminatorias y noticias."
	pageTone="home"
>
	<section class="hero-showcase">
		<div class="hero-copy panel" data-reveal="up">
			<p class="hero-topline">Norteamérica 2026 · edición especial</p>
			<h1 class="hero-title">Un <strong>Mundial</strong> así no se cuenta con prisas.</h1>
			<p class="hero-subtitle">
				Tres países, dieciséis ciudades y ciento cuatro partidos dan para mucho. Aquí está todo lo importante del torneo: el calendario, el cuadro, las sedes y las historias que va dejando por el camino.
			</p>

			<div class="hero-actions">
				<a href="/partidos" class="hero-cta">Ver calendario</a>
				<a href="/sedes" class="hero-cta-secondary">Explorar sedes</a>
			</div>

			<div class="hero-countdown" id="hero-countdown">
				<span id="cuenta-atras" class="hero-countdown__number">{diasRestantes}</span>
				<div class="hero-countdown__copy">
					<strong>Días para el inicio</strong>
					<span>11 de junio · 19 de julio de 2026</span>
				</div>
			</div>
		</div>

		<HostCityConstellation
			layout="hero"
			etiqueta="Escenario continental"
			titulo="Tres países. Un mismo pulso."
			descripcion="Canadá, México y Estados Unidos ponen en marcha un Mundial que va de punta a punta del continente, con escalas muy distintas y noches que ya vienen cargadas."
		/>
	</section>

	<script is:inline>
		(function() {
			var dias = Math.max(0, Math.ceil((new Date('2026-06-11').getTime() - Date.now()) / 864e5))
			var numero = document.getElementById('cuenta-atras')
			var bloque = document.getElementById('hero-countdown')
			if (numero) numero.textContent = String(dias)
			if (bloque && dias === 0) bloque.style.display = 'none'
		})()
	</script>

	<div class="hero-ribbon">
		<div class="hero-ribbon__item panel" data-reveal="up">
			<strong>{totalPartidosEdicion}</strong>
			<span>Partidos en la edición más larga que se recuerda. Va a haber historias para rato.</span>
		</div>
		<div class="hero-ribbon__item panel" data-reveal="up" style="--reveal-delay: 0.08s;">
			<strong>48</strong>
			<span>Selecciones en un formato nuevo, con mejores terceros y un cuadro final bastante más ancho.</span>
		</div>
		<div class="hero-ribbon__item panel" data-reveal="up" style="--reveal-delay: 0.16s;">
			<strong>{totalSedes}</strong>
			<span>Sedes repartidas entre Canadá, México y Estados Unidos. Cada una juega su propio papel en la ruta.</span>
		</div>
	</div>

	<EditorialTicker
		items={[
			{
				label: 'Ruta inaugural',
				value: 'Azteca',
				note: 'México abre el torneo en el Azteca, con todo el peso simbólico que eso arrastra.',
			},
			{
				label: 'Volumen',
				value: `${totalPartidosEdicion} partidos`,
				note: 'El nuevo formato ensancha el calendario y dispara el número de tramas desde el primer día.',
			},
			{
				label: 'Cierre',
				value: 'MetLife',
				note: 'La final apunta a cierre grande, de estadio lleno y noche que se queda en la memoria.',
			},
			{
				label: 'Mapa vivo',
				value: `${totalSedes} sedes`,
				note: 'Cada ciudad mete un clima distinto, pero todas forman parte del mismo viaje.',
			},
		]}
	/>

	<div class="editorial-stack">
		<HostNationCards />

		<section class="editorial-section panel" data-reveal="up">
			<div class="editorial-section__head">
				<div>
					<p class="section-kicker">Encuentra tu selección</p>
					<h2 class="editorial-section__title">Tu puerta de entrada al torneo</h2>
				</div>
			</div>
			<BuscadorEquipos client:load grupos={grupos} slugs={slugsObj} />
		</section>

		<section class="editorial-section panel" data-reveal="up">
			<div class="editorial-section__head">
				<div>
					<p class="section-kicker">Agenda inaugural</p>
					<h2 class="editorial-section__title">Primeros partidos</h2>
				</div>
				<a class="editorial-link" href="/partidos">Ver todos</a>
			</div>

			<div class="match-editorial-grid">
				{proximosPartidos.map((partido) => (
					<article class="match-editorial-card tarjeta tarjeta-hover">
						<div class="match-editorial-card__top">
							<div>
								<p class="match-time" data-utc={partido.fechaUTC}>{partido.hora}</p>
								<p class="match-meta">{partido.fecha}</p>
							</div>
							<span class="score-badge">
								{partido.estado === 'finalizado' ? `${partido.goles1} - ${partido.goles2}` : 'vs'}
							</span>
						</div>

						<div>
							<p class="match-teams">
								<span data-equipo={partido.equipo1}>{partido.equipo1}</span> · <span data-equipo={partido.equipo2}>{partido.equipo2}</span>
							</p>
							<p class="match-meta mt-2">
								{partido.estadio === 'Por confirmar'
									? 'Sede y estadio por confirmar'
									: `${partido.estadio}, ${partido.ciudad}`}
							</p>
						</div>
					</article>
				))}
			</div>
		</section>

		<section class="feature-grid">
			<a href="/grupos" class="feature-link-card tarjeta tarjeta-hover" data-reveal="up">
				<p class="feature-link-card__label">Grupos</p>
				<h3 class="feature-link-card__title">Los grupos, ordenados para ver rápido quién manda y quién aprieta.</h3>
				<p class="feature-link-card__copy">Doce grupos, tabla clara y acceso directo a cada selección sin dar rodeos.</p>
				<span class="feature-link-card__cta">Ver grupos</span>
			</a>
			<a href="/partidos" class="feature-link-card tarjeta tarjeta-hover" data-reveal="up" style="--reveal-delay: 0.06s;">
				<p class="feature-link-card__label">Partidos</p>
				<h3 class="feature-link-card__title">El calendario, contado como agenda del torneo y no como una lista sin alma.</h3>
				<p class="feature-link-card__copy">Filtros rápidos, horarios localizados y una vista mucho más limpia de cada jornada.</p>
				<span class="feature-link-card__cta">Ver agenda</span>
			</a>
			<a href="/eliminatorias" class="feature-link-card tarjeta tarjeta-hover" data-reveal="up" style="--reveal-delay: 0.12s;">
				<p class="feature-link-card__label">Eliminatorias</p>
				<h3 class="feature-link-card__title">El camino al título, claro desde el primer vistazo.</h3>
				<p class="feature-link-card__copy">Del dieciseisavos a la final, con una lectura más limpia y menos ruido visual.</p>
				<span class="feature-link-card__cta">Ver cuadro</span>
			</a>
			<a href="/sedes" class="feature-link-card tarjeta tarjeta-hover" data-reveal="up" style="--reveal-delay: 0.18s;">
				<p class="feature-link-card__label">Sedes</p>
				<h3 class="feature-link-card__title">Las sedes, una por una, para entender qué pinta tiene cada parada.</h3>
				<p class="feature-link-card__copy">Capacidad, localización y el papel que jugará cada estadio en el torneo.</p>
				<span class="feature-link-card__cta">Ver sedes</span>
			</a>
		</section>

		<section class="editorial-section panel" data-reveal="up">
			<div class="editorial-section__head">
				<div>
					<p class="section-kicker">Última hora</p>
					<h2 class="editorial-section__title">Lo último del torneo</h2>
				</div>
				<a class="editorial-link" href="/noticias">Ver noticias</a>
			</div>

			<div class="news-grid">
				{destacadas.map((noticia, index) => (
					<a
						href={`/noticias/${noticia.id}`}
						class="news-card tarjeta tarjeta-hover"
						data-reveal="up"
						style={`--reveal-delay: ${0.08 * index}s;`}
					>
						<NewsStoryArtwork id={noticia.id} title={noticia.data.titulo} />
						<span class="article-kicker">{noticia.data.fecha}</span>
						<h3 class="news-card__title mt-4">{noticia.data.titulo}</h3>
						<p class="news-card__summary mt-3">{noticia.data.resumen}</p>
					</a>
				))}
			</div>
		</section>
	</div>
</Base>
