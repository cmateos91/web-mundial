---
interface Sede {
    ciudad: string
    estadio: string
    capacidad: number
}

interface Props {
    pais: string
    bandera: string
    sedes: Sede[]
    capacidadMax: number
    partidosPorEstadio: Map<string, number>
}

const { pais, bandera, sedes, capacidadMax, partidosPorEstadio } = Astro.props
const formatNum = (n: number) => n.toLocaleString('es-ES')
---

<section class="venue-country" data-reveal="up">
    <div class="venue-country__title">
        <span class="text-3xl">{bandera}</span>
        <h2>{pais}</h2>
    </div>
    <div class="venue-grid">
        {sedes.map(sede => {
            const porcentaje = Math.round((sede.capacidad / capacidadMax) * 100)
            const numPartidos = partidosPorEstadio.get(sede.estadio) ?? 0
            return (
                <article class="venue-card tarjeta tarjeta-hover">
                    <h3 class="venue-card__city">{sede.ciudad}</h3>
                    <p class="venue-card__stadium">{sede.estadio}</p>
                    <div class="mt-3">
                        <div class="flex justify-between text-xs mb-1">
                            <span class="texto-secundario">Capacidad</span>
                            <span class="font-semibold">{formatNum(sede.capacidad)}</span>
                        </div>
                        <div class="venue-capacity-bar">
                            <span style={`width: ${porcentaje}%`}></span>
                        </div>
                    </div>
                    {numPartidos > 0 && (
                        <a href={`/partidos?sede=${encodeURIComponent(sede.estadio)}`} class="feature-link-card__cta">
                            {numPartidos} {numPartidos === 1 ? 'partido' : 'partidos'} programados →
                        </a>
                    )}
                </article>
            )
        })}
    </div>
</section>
