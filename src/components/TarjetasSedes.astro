---
import { hostNationProfileMap } from '../data/editorialAssets'

interface Sede {
    ciudad: string
    estadio: string
    capacidad: number
}

interface Props {
    pais: string
    bandera: string
    sedes: Sede[]
    capacidadMax: number
    partidosPorEstadio: Map<string, number>
}

const { pais, bandera, sedes, capacidadMax, partidosPorEstadio } = Astro.props
const formatNum = (n: number) => n.toLocaleString('es-ES')
const profile = hostNationProfileMap.get(pais)
const capacidadTotal = sedes.reduce((sum, sede) => sum + sede.capacidad, 0)
const partidosTotales = sedes.reduce((sum, sede) => sum + (partidosPorEstadio.get(sede.estadio) ?? 0), 0)
---

<section class="venue-country" id={profile?.slug} data-reveal="up">
    <div class="venue-country__hero panel">
        <div class="venue-country__hero-copy">
            <div class="venue-country__title">
                <span class="venue-country__flag">{bandera}</span>
                <div>
                    <p class="feature-link-card__label">{profile?.kicker ?? 'Escala anfitriona'}</p>
                    <h2>{pais}</h2>
                </div>
            </div>

            <p class="venue-country__summary">
                {profile?.summary ?? `Sedes anfitrionas de ${pais} dentro del recorrido del Mundial 2026.`}
            </p>
            {profile?.spotlight && <p class="venue-country__spotlight">{profile.spotlight}</p>}

            <div class="venue-country__rail">
                <div>
                    <strong>{sedes.length}</strong>
                    <span>sedes</span>
                </div>
                <div>
                    <strong>{formatNum(capacidadTotal)}</strong>
                    <span>plazas</span>
                </div>
                <div>
                    <strong>{partidosTotales}</strong>
                    <span>partidos</span>
                </div>
            </div>
        </div>

        {profile?.asset && (
            <div class="venue-country__poster">
                <img src={profile.asset} alt="" loading="lazy" />
            </div>
        )}
    </div>

    <div class="venue-grid">
        {sedes.map(sede => {
            const porcentaje = Math.round((sede.capacidad / capacidadMax) * 100)
            const numPartidos = partidosPorEstadio.get(sede.estadio) ?? 0
            return (
                <article class="venue-card tarjeta tarjeta-hover">
                    <h3 class="venue-card__city">{sede.ciudad}</h3>
                    <p class="venue-card__stadium">{sede.estadio}</p>
                    <div class="mt-3">
                        <div class="flex justify-between text-xs mb-1">
                            <span class="texto-secundario">Capacidad</span>
                            <span class="font-semibold">{formatNum(sede.capacidad)}</span>
                        </div>
                        <div class="venue-capacity-bar">
                            <span style={`width: ${porcentaje}%`}></span>
                        </div>
                    </div>
                    {numPartidos > 0 && (
                        <a href={`/partidos?sede=${encodeURIComponent(sede.estadio)}`} class="feature-link-card__cta">
                            {numPartidos} {numPartidos === 1 ? 'partido' : 'partidos'} programados →
                        </a>
                    )}
                </article>
            )
        })}
    </div>
</section>
