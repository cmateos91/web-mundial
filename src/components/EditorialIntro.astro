---
interface Stat {
  valor: string
  etiqueta: string
}

interface Props {
  etiqueta: string
  titulo: string
  descripcion: string
  stats?: Stat[]
}

const { etiqueta, titulo, descripcion, stats = [] } = Astro.props
---

<section class="page-intro" data-reveal="up">
  <div class="page-intro__frame">
    <p class="section-kicker">{etiqueta}</p>
    <div class="page-intro__grid">
      <div class="page-intro__copy">
        <h1 class="page-title">{titulo}</h1>
        <p class="page-lead">{descripcion}</p>
      </div>
      {stats.length > 0 && (
        <div class="page-intro__stats">
          {stats.map((stat) => (
            <div class="stat-card">
              <strong>{stat.valor}</strong>
              <span>{stat.etiqueta}</span>
            </div>
          ))}
        </div>
      )}
    </div>
    <slot />
  </div>
</section>
