---
interface Sede {
    ciudad: string
    estadio: string
    capacidad: number
}

interface Props {
    pais: string
    sedes: Sede[]
}

const {pais, sedes} = Astro.props
const formatNum = (n: number) => n.toLocaleString('es-ES')
---

<h2 class="text-2xl font-bold mt-8 mb-2">{pais}</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {sedes.map(sede =>(
            <div class="p-4 border rounded">
                <h3 class="text-lg font-semibold">{sede.ciudad}</h3>
                <p>{sede.estadio}</p>
                <p>{formatNum(sede.capacidad)} espectadores</p>
            </div>
        ))}
    </div>