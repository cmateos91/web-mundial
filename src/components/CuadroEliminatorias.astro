---
import type { PartidoEliminatoria, Ronda } from '../data/eliminatorias'

interface Props {
	rondas: Ronda[]
}

const { rondas } = Astro.props

const rondaTercerPuesto = rondas.find((ronda) => ronda.nombre === 'Tercer puesto')
const rondasCamino = rondas.filter((ronda) => ronda.nombre !== 'Tercer puesto')

const rondasInfo: Record<string, { kicker: string; accent: string; note: string }> = {
	Dieciseisavos: {
		kicker: 'Corte inicial',
		accent: '32 -> 16',
		note: 'La primera gran criba del cuadro.',
	},
	'Octavos de final': {
		kicker: 'Segundo filtro',
		accent: '16 -> 8',
		note: 'Empieza a verse con claridad el camino de cada lado.',
	},
	'Cuartos de final': {
		kicker: 'Zona noble',
		accent: '8 -> 4',
		note: 'Ya no quedan cruces de paso: todo pesa.',
	},
	Semifinales: {
		kicker: 'Antesala',
		accent: '4 -> 2',
		note: 'Solo dos proyectos sobreviven para la final.',
	},
	Final: {
		kicker: 'Climax',
		accent: '1 campeon',
		note: 'Una noche, un trofeo.',
	},
}

const resumenRondas = rondasCamino.map((ronda) => ({
	nombre:
		ronda.nombre === 'Octavos de final'
			? 'Octavos'
			: ronda.nombre === 'Cuartos de final'
				? 'Cuartos'
				: ronda.nombre,
	valor: `${ronda.partidos.length} ${ronda.partidos.length === 1 ? 'cruce' : 'cruces'}`,
	esFinal: ronda.nombre === 'Final',
}))

function metaPartido(partido: PartidoEliminatoria) {
	if (partido.estado === 'finalizado' && partido.goles1 !== null && partido.goles2 !== null) {
		return {
			status: 'Finalizado',
			className: 'knockout-match__status knockout-match__status--final',
			ganador: partido.goles1 > partido.goles2 ? partido.equipo1 : partido.equipo2,
		}
	}

	if (partido.estado === 'en_juego') {
		return {
			status: 'En juego',
			className: 'knockout-match__status knockout-match__status--live',
			ganador: null,
		}
	}

	return {
		status: 'Pendiente',
		className: 'knockout-match__status knockout-match__status--scheduled',
		ganador: null,
	}
}

function etiquetaCruce(ronda: string, indice: number) {
	if (ronda === 'Final') return 'Partido por el titulo'
	if (ronda === 'Tercer puesto') return 'Partido por el bronce'
	return `Cruce ${String(indice + 1).padStart(2, '0')}`
}
---

<div class="knockout-journey" data-reveal="up">
	<section class="knockout-overview">
		<div class="knockout-overview__head">
			<p class="section-kicker">Vista total</p>
			<h3 class="feature-title">Primero ves la ruta completa. Luego bajas al detalle.</h3>
			<p class="feature-copy">El cuadro ya no se desborda en horizontal: se resume arriba y se desarrolla debajo por fases, con una lectura mucho mas limpia.</p>
		</div>

		<div class="knockout-overview__map" aria-hidden="true">
			<svg viewBox="0 0 1000 220" class="knockout-overview__svg">
				<path d="M90 160 C170 160 175 90 250 90 S345 160 420 160 S515 90 580 90 S675 160 750 160 S825 120 900 120" class="knockout-overview__track" />
				{rondaTercerPuesto && (
					<path d="M750 160 C785 160 805 184 805 206" class="knockout-overview__track knockout-overview__track--minor" />
				)}
				<circle cx="90" cy="160" r="7" class="knockout-overview__node" />
				<circle cx="250" cy="90" r="7" class="knockout-overview__node" />
				<circle cx="420" cy="160" r="7" class="knockout-overview__node" />
				<circle cx="580" cy="90" r="7" class="knockout-overview__node" />
				<circle cx="900" cy="120" r="9" class="knockout-overview__node knockout-overview__node--final" />
				{rondaTercerPuesto && <circle cx="805" cy="206" r="5" class="knockout-overview__node" />}
			</svg>
		</div>

		<div class="knockout-overview__legend">
			{resumenRondas.map((ronda) => (
				<article class:list={['knockout-overview__chip', { 'knockout-overview__chip--final': ronda.esFinal }]}>
					<p>{ronda.nombre}</p>
					<strong>{ronda.valor}</strong>
				</article>
			))}

			{rondaTercerPuesto && (
				<article class="knockout-overview__chip knockout-overview__chip--minor">
					<p>Bronce</p>
					<strong>1 cruce</strong>
				</article>
			)}
		</div>
	</section>

	<div class="knockout-rounds">
		{rondasCamino.map((ronda, rondaIdx) => {
			const info = rondasInfo[ronda.nombre] ?? {
				kicker: 'Ronda',
				accent: `${ronda.partidos.length} cruces`,
				note: 'Siguiente tramo del cuadro.',
			}
			const esFinal = ronda.nombre === 'Final'
			const gridClass = `knockout-round__grid--${ronda.partidos.length}`

			return (
				<section class:list={['knockout-round', { 'knockout-round--final': esFinal }]}>
					<div class="knockout-round__head">
						<div class="knockout-round__title">
							<span class="knockout-round__index">{String(rondaIdx + 1).padStart(2, '0')}</span>
							<div class="knockout-round__copy">
								<p class="section-kicker">{info.kicker}</p>
								<h3 class="feature-title">{ronda.nombre}</h3>
							</div>
						</div>

						<div class="knockout-round__summary">
							<p class="knockout-round__accent">{info.accent}</p>
							<p class="knockout-round__note">{info.note}</p>
						</div>
					</div>

					<div class:list={['knockout-round__grid', gridClass, { 'knockout-round__grid--final': esFinal }]}>
						{ronda.partidos.map((partido, indice) => {
							const meta = metaPartido(partido)
							const hayResultado = partido.estado === 'finalizado' && partido.goles1 !== null && partido.goles2 !== null
							const pendiente = partido.equipo1 === 'Por definir' || partido.equipo2 === 'Por definir'

							return (
								<article class:list={['knockout-match', { 'knockout-match--pending': pendiente, 'knockout-match--final': esFinal }]}>
									<div class="knockout-match__meta">
										<span class={meta.className}>{meta.status}</span>
										<span class="knockout-match__label">{etiquetaCruce(ronda.nombre, indice)}</span>
									</div>

									<div class:list={['knockout-match__team', { ganador: meta.ganador === partido.equipo1, perdedor: meta.ganador && meta.ganador !== partido.equipo1, 'knockout-match__team--pending': partido.equipo1 === 'Por definir' }]}>
										<span class="truncate" data-equipo={partido.equipo1 !== 'Por definir' ? partido.equipo1 : undefined}>
											{partido.equipo1}
										</span>
										{hayResultado && <span class="knockout-match__score">{partido.goles1}</span>}
									</div>

									<div class:list={['knockout-match__team', { ganador: meta.ganador === partido.equipo2, perdedor: meta.ganador && meta.ganador !== partido.equipo2, 'knockout-match__team--pending': partido.equipo2 === 'Por definir' }]}>
										<span class="truncate" data-equipo={partido.equipo2 !== 'Por definir' ? partido.equipo2 : undefined}>
											{partido.equipo2}
										</span>
										{hayResultado && <span class="knockout-match__score">{partido.goles2}</span>}
									</div>
								</article>
							)
						})}
					</div>

					{esFinal && rondaTercerPuesto && (
						<div class="knockout-round__extra">
							<div class="knockout-round__extra-head">
								<p class="section-kicker">Epílogo</p>
								<h3 class="feature-title">Tercer puesto</h3>
							</div>

							{rondaTercerPuesto.partidos.map((partido, indice) => {
								const meta = metaPartido(partido)
								const hayResultado = partido.estado === 'finalizado' && partido.goles1 !== null && partido.goles2 !== null
								const pendiente = partido.equipo1 === 'Por definir' || partido.equipo2 === 'Por definir'

								return (
									<article class:list={['knockout-match', 'knockout-match--minor', { 'knockout-match--pending': pendiente }]}>
										<div class="knockout-match__meta">
											<span class={meta.className}>{meta.status}</span>
											<span class="knockout-match__label">{etiquetaCruce(rondaTercerPuesto.nombre, indice)}</span>
										</div>

										<div class:list={['knockout-match__team', { ganador: meta.ganador === partido.equipo1, perdedor: meta.ganador && meta.ganador !== partido.equipo1, 'knockout-match__team--pending': partido.equipo1 === 'Por definir' }]}>
											<span class="truncate" data-equipo={partido.equipo1 !== 'Por definir' ? partido.equipo1 : undefined}>
												{partido.equipo1}
											</span>
											{hayResultado && <span class="knockout-match__score">{partido.goles1}</span>}
										</div>

										<div class:list={['knockout-match__team', { ganador: meta.ganador === partido.equipo2, perdedor: meta.ganador && meta.ganador !== partido.equipo2, 'knockout-match__team--pending': partido.equipo2 === 'Por definir' }]}>
											<span class="truncate" data-equipo={partido.equipo2 !== 'Por definir' ? partido.equipo2 : undefined}>
												{partido.equipo2}
											</span>
											{hayResultado && <span class="knockout-match__score">{partido.goles2}</span>}
										</div>
									</article>
								)
							})}
						</div>
					)}
				</section>
			)
		})}
	</div>
</div>

<style>
	.knockout-journey {
		display: grid;
		gap: 1.1rem;
	}

	.knockout-overview,
	.knockout-round {
		border: 1px solid var(--color-borde);
		border-radius: 1.35rem;
		background:
			linear-gradient(180deg, rgb(255 255 255 / 0.08), transparent 18%),
			color-mix(in srgb, var(--color-tarjeta) 90%, transparent);
		box-shadow: 0 18px 34px -30px var(--color-sombra);
	}

	.knockout-overview {
		display: grid;
		gap: 1rem;
		padding: 1rem;
	}

	.knockout-overview__head {
		display: grid;
		gap: 0.7rem;
		max-width: 42rem;
	}

	.knockout-overview__map {
		border-radius: 1rem;
		border: 1px solid color-mix(in srgb, var(--page-accent) 16%, var(--color-borde));
		background:
			radial-gradient(circle at 50% 50%, color-mix(in srgb, var(--page-accent) 8%, transparent), transparent 62%),
			color-mix(in srgb, var(--color-superficie) 84%, transparent);
		padding: 0.5rem;
	}

	.knockout-overview__svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.knockout-overview__track {
		fill: none;
		stroke: color-mix(in srgb, var(--page-accent) 58%, var(--color-borde));
		stroke-width: 3;
		stroke-linecap: round;
	}

	.knockout-overview__track--minor {
		stroke-width: 2;
		stroke-dasharray: 8 8;
		opacity: 0.82;
	}

	.knockout-overview__node {
		fill: color-mix(in srgb, var(--page-accent) 95%, white 5%);
		stroke: color-mix(in srgb, var(--page-accent) 38%, var(--color-borde));
		stroke-width: 2;
	}

	.knockout-overview__node--final {
		fill: color-mix(in srgb, var(--color-oro) 82%, white 18%);
		stroke: color-mix(in srgb, var(--color-oro) 52%, var(--color-borde));
	}

	.knockout-overview__legend {
		display: grid;
		gap: 0.75rem;
		grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
	}

	.knockout-overview__chip {
		display: grid;
		gap: 0.2rem;
		padding: 0.8rem 0.9rem;
		border-radius: 0.95rem;
		border: 1px solid var(--color-borde);
		background: color-mix(in srgb, var(--color-superficie) 82%, transparent);
	}

	.knockout-overview__chip p,
	.knockout-overview__chip strong {
		margin: 0;
	}

	.knockout-overview__chip p {
		font-family: var(--font-ui);
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-texto-secundario);
	}

	.knockout-overview__chip strong {
		font-size: 1rem;
	}

	.knockout-overview__chip--final {
		border-color: color-mix(in srgb, var(--color-oro) 50%, var(--color-borde));
	}

	.knockout-overview__chip--minor {
		border-style: dashed;
	}

	.knockout-rounds {
		display: grid;
		gap: 1rem;
	}

	.knockout-round {
		display: grid;
		gap: 1rem;
		padding: 1rem;
	}

	.knockout-round__head {
		display: grid;
		gap: 0.8rem;
	}

	.knockout-round__title {
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
	}

	.knockout-round__index {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.1rem;
		height: 2.1rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--page-accent) 40%, var(--color-borde));
		background: color-mix(in srgb, var(--page-accent) 10%, transparent);
		font-family: var(--font-ui);
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		color: var(--page-accent);
	}

	.knockout-round__copy {
		display: grid;
		gap: 0.45rem;
	}

	.knockout-round__summary {
		display: grid;
		gap: 0.25rem;
	}

	.knockout-round__accent,
	.knockout-round__note {
		margin: 0;
	}

	.knockout-round__accent {
		font-family: var(--font-ui);
		font-size: 0.76rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--color-texto-secundario);
	}

	.knockout-round__note {
		color: var(--color-texto-secundario);
	}

	.knockout-round__grid {
		display: grid;
		gap: 0.85rem;
	}

	.knockout-round__grid--16,
	.knockout-round__grid--8,
	.knockout-round__grid--4,
	.knockout-round__grid--2 {
		grid-template-columns: repeat(auto-fit, minmax(13.5rem, 1fr));
	}

	.knockout-round__grid--1 {
		grid-template-columns: minmax(0, 1fr);
		max-width: 28rem;
	}

	.knockout-round__grid--final {
		align-items: start;
	}

	.knockout-round__extra {
		display: grid;
		gap: 0.75rem;
		padding-top: 0.25rem;
		max-width: 28rem;
	}

	.knockout-round__extra-head {
		display: grid;
		gap: 0.35rem;
	}

	.knockout-match {
		display: grid;
		min-width: 0;
		border: 1px solid var(--color-borde);
		border-radius: 1rem;
		background:
			linear-gradient(135deg, rgb(255 255 255 / 0.1), transparent 38%),
			color-mix(in srgb, var(--color-superficie) 88%, transparent);
		overflow: hidden;
	}

	.knockout-match--final {
		border-width: 2px;
		border-color: color-mix(in srgb, var(--color-oro) 54%, var(--color-borde));
		box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-oro) 18%, transparent);
	}

	.knockout-match--minor {
		border-style: dashed;
	}

	.knockout-match--pending {
		opacity: 0.96;
	}

	.knockout-match__meta {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.65rem;
		padding: 0.55rem 0.7rem;
		border-bottom: 1px solid var(--color-borde);
		background: color-mix(in srgb, var(--color-superficie) 74%, transparent);
	}

	.knockout-match__status,
	.knockout-match__label {
		display: inline-flex;
		align-items: center;
		padding: 0.16rem 0.5rem;
		border-radius: 999px;
		font-family: var(--font-ui);
		font-size: 0.64rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.knockout-match__status {
		border: 1px solid var(--color-borde);
	}

	.knockout-match__status--scheduled {
		color: var(--color-texto-secundario);
		background: color-mix(in srgb, var(--color-superficie) 72%, transparent);
	}

	.knockout-match__status--live {
		color: var(--color-rojo);
		border-color: color-mix(in srgb, var(--color-rojo) 45%, var(--color-borde));
		background: color-mix(in srgb, var(--color-rojo) 10%, transparent);
	}

	.knockout-match__status--final {
		color: var(--page-accent);
		border-color: color-mix(in srgb, var(--page-accent) 36%, var(--color-borde));
		background: color-mix(in srgb, var(--page-accent) 10%, transparent);
	}

	.knockout-match__label {
		color: var(--color-texto-secundario);
	}

	.knockout-match__team {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.5rem;
		padding: 0.72rem 0.8rem;
	}

	.knockout-match__team + .knockout-match__team {
		border-top: 1px solid var(--color-borde);
	}

	.knockout-match__team.ganador {
		background: color-mix(in srgb, var(--color-oro) 10%, transparent);
		font-weight: 700;
	}

	.knockout-match__team.perdedor {
		opacity: 0.58;
	}

	.knockout-match__team--pending {
		color: var(--color-texto-secundario);
		font-style: italic;
	}

	.knockout-match__score {
		min-width: 1.5rem;
		text-align: center;
		font-family: var(--font-ui);
		font-size: 1rem;
		font-weight: 700;
	}

	@media (min-width: 900px) {
		.knockout-round__head {
			grid-template-columns: minmax(0, 1fr) auto;
			align-items: end;
		}

		.knockout-round--final {
			grid-template-columns: minmax(0, 1fr) minmax(18rem, 20rem);
		}

		.knockout-round--final .knockout-round__head,
		.knockout-round--final .knockout-round__grid {
			grid-column: 1;
		}

		.knockout-round--final .knockout-round__extra {
			grid-column: 2;
			grid-row: 1 / span 2;
			align-self: start;
		}
	}

	@media (max-width: 699px) {
		.knockout-match__meta {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
