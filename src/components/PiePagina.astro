---
import { enlaces } from '../data/navegacion'
---

<footer class="border-t border-[var(--color-borde)] mt-auto">
    <div class="max-w-6xl mx-auto px-4 py-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <p class="font-bold"><span class="text-[var(--color-verde)]">Mundial</span> 2026</p>
                <p class="text-xs texto-secundario mt-1">Sitio no oficial. Proyecto educativo.</p>
            </div>
            <nav class="flex flex-wrap gap-4">
                {enlaces.map(({ href, texto }) => (
                    <a href={href} class="text-sm texto-secundario hover:text-[var(--color-verde)] transition-colors">
                        {texto}
                    </a>
                ))}
            </nav>
        </div>
    </div>
</footer>
