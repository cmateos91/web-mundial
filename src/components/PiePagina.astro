---
import { enlaces } from '../data/navegacion'
---

<footer class="footer mt-auto">
    <div class="footer__inner">
        <div class="footer__panel panel">
            <div class="footer__grid">
                <div class="footer__brand">
                    <p><span>Mundial</span> 2026</p>
                    <p class="footer__note mt-2">Edición especial sobre el torneo de Canadá, México y Estados Unidos.</p>
                    <p class="footer__note mt-1 text-sm">Sitio no oficial. Proyecto educativo y experimental.</p>
                </div>

                <div class="grid gap-4">
                    <nav class="footer__links">
                        {enlaces.map(({ href, texto }) => (
                            <a href={href} class="footer__link">
                                {texto}
                            </a>
                        ))}
                    </nav>

                    <div class="footer__host-strip">
                        <span class="footer__host-pill">🇨🇦 Canadá</span>
                        <span class="footer__host-pill">🇲🇽 México</span>
                        <span class="footer__host-pill">🇺🇸 Estados Unidos</span>
                    </div>

                    <p class="footer__note text-sm">
                        48 selecciones, 16 sedes, 104 partidos y un torneo que cruza todo el continente de junio a julio.
                    </p>
                </div>
            </div>
        </div>
    </div>
</footer>
