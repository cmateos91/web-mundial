---
import SelectorPais from './SelectorPais.astro'

interface Props {
    rutaActual: string
}

const { rutaActual } = Astro.props

const enlaces = [
    { href: '/', texto: 'Inicio' },
    { href: '/partidos', texto: 'Partidos' },
    { href: '/grupos', texto: 'Grupos' },
    { href: '/eliminatorias', texto: 'Eliminatorias' },
    { href: '/sedes', texto: 'Sedes' },
    { href: '/noticias', texto: 'Noticias' },
]

function esActivo(href: string, ruta: string): boolean {
    if (href === '/') return ruta === '/'
    return ruta.startsWith(href)
}
---

<nav class="sticky top-0 z-50 bg-[var(--color-tarjeta)] border-b border-[var(--color-borde)] backdrop-blur-sm">
    <div class="max-w-6xl mx-auto px-4 flex items-center justify-between h-14">
        <!-- Logo / nombre -->
        <a href="/" class="text-lg font-bold tracking-tight">
            <span class="text-[var(--color-verde)]">Mundial</span> 2026
        </a>

        <!-- Links desktop -->
        <div class="hidden md:flex items-center gap-1">
            {enlaces.map(({ href, texto }) => (
                <a
                    href={href}
                    class:list={[
                        'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
                        esActivo(href, rutaActual)
                            ? 'bg-[var(--color-verde)] text-white'
                            : 'hover:bg-[var(--color-superficie)]'
                    ]}
                >
                    {texto}
                </a>
            ))}
            <div class="ml-2">
                <SelectorPais />
            </div>
            <button
                id="btn-tema"
                class="p-2 rounded-lg hover:bg-[var(--color-superficie)] transition-colors"
                aria-label="Cambiar tema"
            >
                <span id="icono-tema-sol" class="hidden">&#9728;</span>
                <span id="icono-tema-luna" class="hidden">&#9790;</span>
            </button>
        </div>

        <!-- Controles móvil -->
        <div class="flex items-center gap-1 md:hidden">
            <SelectorPais />
            <button
                id="btn-tema-movil"
                class="p-2 rounded-lg hover:bg-[var(--color-superficie)] transition-colors"
                aria-label="Cambiar tema"
            >
                <span id="icono-tema-sol-movil" class="hidden">&#9728;</span>
                <span id="icono-tema-luna-movil" class="hidden">&#9790;</span>
            </button>
            <button
                id="btn-menu"
                class="p-2 rounded-lg hover:bg-[var(--color-superficie)] transition-colors"
                aria-label="Abrir menú"
            >
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path id="icono-menu" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                    <path id="icono-cerrar" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Menú móvil -->
    <div id="menu-movil" class="hidden md:hidden border-t border-[var(--color-borde)] pb-2">
        {enlaces.map(({ href, texto }) => (
            <a
                href={href}
                class:list={[
                    'block px-4 py-2.5 text-sm font-medium transition-colors',
                    esActivo(href, rutaActual)
                        ? 'bg-[var(--color-verde)] text-white mx-2 rounded-lg'
                        : 'hover:bg-[var(--color-superficie)]'
                ]}
            >
                {texto}
            </a>
        ))}
    </div>
</nav>

<script is:inline>
    function inicializarNavbar() {
        // --- Menú hamburguesa ---
        var btnMenu = document.getElementById('btn-menu')
        var menuMovil = document.getElementById('menu-movil')
        var iconoMenu = document.getElementById('icono-menu')
        var iconoCerrar = document.getElementById('icono-cerrar')

        if (btnMenu) {
            btnMenu.onclick = function() {
                menuMovil.classList.toggle('hidden')
                iconoMenu.classList.toggle('hidden')
                iconoCerrar.classList.toggle('hidden')
            }
        }

        // --- Dark mode toggle ---
        var esDark = document.documentElement.classList.contains('dark')

        // Actualizar iconos
        var ids = ['icono-tema-sol', 'icono-tema-luna', 'icono-tema-sol-movil', 'icono-tema-luna-movil']
        ids.forEach(function(id) {
            var el = document.getElementById(id)
            if (!el) return
            var esSol = id.includes('sol')
            el.classList.toggle('hidden', esSol ? !esDark : esDark)
        })

        // Botones de tema
        function alternarTema() {
            document.documentElement.classList.toggle('dark')
            var dark = document.documentElement.classList.contains('dark')
            localStorage.setItem('dark', String(dark))
            inicializarNavbar()
        }

        var btnTema = document.getElementById('btn-tema')
        var btnTemaMovil = document.getElementById('btn-tema-movil')
        if (btnTema) btnTema.onclick = alternarTema
        if (btnTemaMovil) btnTemaMovil.onclick = alternarTema
    }

    inicializarNavbar()
    document.addEventListener('astro:page-load', inicializarNavbar)
</script>
