---
import SelectorPais from './SelectorPais.astro'
import { enlaces } from '../data/navegacion'

interface Props {
    rutaActual: string
}

const { rutaActual } = Astro.props

function esActivo(href: string, ruta: string): boolean {
    if (href === '/') return ruta === '/'
    return ruta.startsWith(href)
}
---

<nav class="site-nav">
    <div class="site-nav__inner">
        <div class="site-nav__bar panel">
            <a href="/" class="brand-mark">
                <span class="brand-kicker">Edición especial</span>
                <span class="brand-wordmark"><span>Mundial</span> 2026</span>
            </a>

            <div class="site-nav__desktop hidden lg:flex">
                {enlaces.map(({ href, texto }) => (
                    <a
                        href={href}
                        class:list={[
                            'nav-link',
                            { 'is-active': esActivo(href, rutaActual) }
                        ]}
                    >
                        {texto}
                    </a>
                ))}
                <SelectorPais />
                <button
                    id="btn-tema"
                    class="theme-toggle"
                    aria-label="Cambiar tema"
                >
                    <span id="icono-tema-sol" class="hidden">☀</span>
                    <span id="icono-tema-luna" class="hidden">◐</span>
                </button>
            </div>

            <div class="site-nav__mobile-actions flex lg:hidden">
                <SelectorPais />
                <button
                    id="btn-tema-movil"
                    class="theme-toggle"
                    aria-label="Cambiar tema"
                >
                    <span id="icono-tema-sol-movil" class="hidden">☀</span>
                    <span id="icono-tema-luna-movil" class="hidden">◐</span>
                </button>
                <button
                    id="btn-menu"
                    class="menu-toggle"
                    aria-label="Abrir menú"
                    aria-expanded="false"
                >
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path id="icono-menu" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 6h16M4 12h16M4 18h16" />
                        <path id="icono-cerrar" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <div class="site-nav__inner lg:hidden">
        <div id="menu-movil" class="site-nav__mobile-menu hidden">
            <div class="mobile-menu-panel panel">
                {enlaces.map(({ href, texto }) => (
                    <a
                        href={href}
                        class:list={[
                            'mobile-menu-link',
                            { 'is-active': esActivo(href, rutaActual) }
                        ]}
                    >
                        {texto}
                    </a>
                ))}
            </div>
        </div>
    </div>
</nav>

<script is:inline>
    function inicializarNavbar() {
        // --- Menú hamburguesa ---
        var btnMenu = document.getElementById('btn-menu')
        var menuMovil = document.getElementById('menu-movil')
        var iconoMenu = document.getElementById('icono-menu')
        var iconoCerrar = document.getElementById('icono-cerrar')

        if (btnMenu) {
            btnMenu.onclick = function() {
                menuMovil.classList.toggle('hidden')
                iconoMenu.classList.toggle('hidden')
                iconoCerrar.classList.toggle('hidden')
                btnMenu.setAttribute('aria-expanded', String(!menuMovil.classList.contains('hidden')))
            }
        }

        // --- Dark mode toggle ---
        var esDark = document.documentElement.classList.contains('dark')

        // Actualizar iconos
        var ids = ['icono-tema-sol', 'icono-tema-luna', 'icono-tema-sol-movil', 'icono-tema-luna-movil']
        ids.forEach(function(id) {
            var el = document.getElementById(id)
            if (!el) return
            var esSol = id.includes('sol')
            el.classList.toggle('hidden', esSol ? !esDark : esDark)
        })

        // Botones de tema
        function alternarTema() {
            document.documentElement.classList.toggle('dark')
            var dark = document.documentElement.classList.contains('dark')
            localStorage.setItem('dark', String(dark))
            inicializarNavbar()
        }

        var btnTema = document.getElementById('btn-tema')
        var btnTemaMovil = document.getElementById('btn-tema-movil')
        if (btnTema) btnTema.onclick = alternarTema
        if (btnTemaMovil) btnTemaMovil.onclick = alternarTema
    }

    inicializarNavbar()
    document.addEventListener('astro:page-load', inicializarNavbar)
</script>
