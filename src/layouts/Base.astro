---
import '../styles/global.css'
import { ClientRouter } from 'astro:transitions'
import Navbar from '../components/Navbar.astro'
import PiePagina from '../components/PiePagina.astro'
import AtmosphericBackdrop from '../components/AtmosphericBackdrop.astro'
import { paises } from '../data/paises'

const { titulo, descripcion = 'Toda la información del Mundial 2026: grupos, partidos, sedes y más', pageTone = 'home' } = Astro.props

// Serializar el mapa país→zona para el script inline
const zonasJSON = JSON.stringify(Object.fromEntries(paises.map(p => [p.nombre, p.zona])))
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="description" content={descripcion} />
        <meta name="theme-color" content="#07131b" />
        <title>{titulo}</title>
        <ClientRouter />
        <!-- Dark mode sin FOUC (también funciona con View Transitions) -->
        <script is:inline>
            function aplicarTema() {
                if (localStorage.getItem('dark') === 'true') {
                    document.documentElement.classList.add('dark')
                }
            }
            aplicarTema()
            document.addEventListener('astro:after-swap', aplicarTema)
        </script>
    </head>
    <body class="min-h-screen flex flex-col" data-page-tone={pageTone}>
        <AtmosphericBackdrop tone={pageTone} />
        <div class="site-frame min-h-screen flex flex-col">
        <Navbar rutaActual={Astro.url.pathname} />
        <main class="site-main w-full flex-1">
            <slot />
        </main>
        <PiePagina />
        </div>
        <!-- Conversión de horas + resaltado de equipo -->
        <script is:inline define:vars={{ zonasJSON }}>
            function aplicarPreferencias() {
                var zonas = JSON.parse(zonasJSON)
                var pais = localStorage.getItem('pais')
                if (!pais) return

                var zona = zonas[pais]

                if (zona) {
                    document.querySelectorAll('[data-utc]').forEach(function(el) {
                        try {
                            var fecha = new Date(el.getAttribute('data-utc'))
                            el.textContent = fecha.toLocaleTimeString('es-ES', {
                                timeZone: zona, hour: '2-digit', minute: '2-digit', hour12: false
                            })
                        } catch(e) {}
                    })
                }

                document.querySelectorAll('[data-equipo]').forEach(function(el) {
                    if (el.getAttribute('data-equipo') === pais) {
                        el.classList.add('equipo-favorito')
                    }
                })
            }

            // Ejecutar en carga normal y en navegación con View Transitions
            aplicarPreferencias()
            document.addEventListener('astro:page-load', aplicarPreferencias)
        </script>
        <script is:inline>
            function inicializarReveals() {
                var elementos = Array.from(document.querySelectorAll('[data-reveal]'))
                if (!elementos.length) return

                if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
                    elementos.forEach(function(el) {
                        el.classList.add('is-visible')
                    })
                    return
                }

                var observer = new IntersectionObserver(function(entries) {
                    entries.forEach(function(entry) {
                        if (!entry.isIntersecting) return
                        entry.target.classList.add('is-visible')
                        observer.unobserve(entry.target)
                    })
                }, {
                    threshold: 0.16,
                    rootMargin: '0px 0px -8% 0px'
                })

                elementos.forEach(function(el) {
                    if (el.classList.contains('is-visible')) return
                    observer.observe(el)
                })
            }

            inicializarReveals()
            document.addEventListener('astro:page-load', inicializarReveals)
        </script>
    </body>
</html>
